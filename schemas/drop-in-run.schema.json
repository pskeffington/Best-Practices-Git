{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DropInRunRecord",
  "type": "object",
  "required": ["name", "status", "metrics", "artifacts", "claims"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "NEEDS_WORK"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "string"]
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "required": ["text", "level", "evidence_path", "evidence_description", "boundary_note"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "string",
          "enum": ["descriptive", "predictive", "comparative", "interpretive", "generalizable", "actionable"]
        },
        "evidence_path": {
          "type": "string",
          "minLength": 1
        },
        "evidence_description": {
          "type": "string",
          "minLength": 1
        },
        "boundary_note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
